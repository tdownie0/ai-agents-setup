{
  "name": "model_md_root",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build --if-present",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "dev:server": "pnpm --filter @model_md/backend dev",
    "dev:client": "pnpm --filter @model_md/frontend dev",
    "dev": "concurrently \"pnpm:dev:server\" \"pnpm:dev:client\"",
    "back:build": "pnpm --filter @model_md/backend build",
    "front:build": "pnpm --filter @model_md/frontend build",
    "db:check": "pnpm --filter @model_md/database db:check",
    "db:generate": "pnpm --filter @model_md/database db:generate",
    "db:migrate": "pnpm --filter @model_md/database db:migrate",
    "db:seed": "pnpm --filter @model_md/database seed",
    "db:seed:clear": "pnpm --filter @model_md/database seed:clear",
    "db:reset": "pnpm --filter @model_md/database db:reset",
    "test:db": "pnpm --filter @model_md/database test",
    "typecheck": "pnpm exec tsc --build --verbose",
    "clean": "find . -name '*.tsbuildinfo' -delete && find . -name 'dist' -type d -exec rm -rf {} +"
  },
  "dependencies": {
    "@faker-js/faker": "^9.9.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "concurrently": "^9.2.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.30.3"
}
