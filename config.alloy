// 1. Discover Docker containers
discovery.docker "all_containers" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "clean_docker_names" {
  targets = discovery.docker.all_containers.targets

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "service_name"
    replacement   = "$1"
  }
}

// 2. Collect Logs and send to Loki
loki.source.docker "logs" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.clean_docker_names.output
  forward_to = [loki.write.local_loki.receiver]
}

loki.write "local_loki" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}

// 3. Collect Metrics and send to Prometheus
prometheus.scrape "metrics" {
  targets    = discovery.docker.all_containers.targets
  forward_to = [prometheus.remote_write.local_prom.receiver]
}

prometheus.remote_write "local_prom" {
  endpoint {
    url = "http://prometheus:9090/api/v1/write"
  }
}
