# --- Stage 1: Build Beads from source ---
# We use golang:alpine to ensure we have a full build environment
FROM golang:alpine AS beads-builder

RUN apk add --no-cache curl tar

# Build Beads (bd CLI)
RUN curl -fsSL https://github.com/gastownhall/beads/archive/refs/heads/main.tar.gz -o /tmp/beads.tar.gz && \
    tar -xzf /tmp/beads.tar.gz -C /tmp && \
    cd /tmp/beads-main && \
    CGO_ENABLED=0 go build -o /usr/local/bin/bd ./cmd/bd

# Download Dolt (Database backend)
RUN curl -fsSL https://github.com/dolthub/dolt/releases/download/v1.85.0/dolt-linux-amd64.tar.gz -o /tmp/dolt.tar.gz && \
    tar -xzf /tmp/dolt.tar.gz -C /tmp && \
    mv /tmp/dolt-linux-amd64/bin/dolt /usr/local/bin/dolt

# --- Stage 2: Final Image ---
FROM node:22-alpine

USER root

# Install runtime dependencies
RUN apk add --no-cache \
    curl \
    bash \
    unzip \
    icu-libs \
    gcompat

COPY --from=beads-builder /usr/local/bin/bd /usr/local/bin/bd
COPY --from=beads-builder /usr/local/bin/dolt /usr/local/bin/dolt

# Create the Git Shim for Beads stealth mode
# This allows 'bd init' to work without a real git installation
RUN echo -e '#!/bin/sh\nexit 0' > /usr/local/bin/git && \
    chmod +x /usr/local/bin/git

# Install Pi AI coding tool globally via npm
RUN npm install -g @earendil-works/pi-coding-agent

RUN mkdir -p /app \
             /home/node/.pi/agent/extensions \
             /home/node/.pi/agent/skills \
             /home/node/.pi/agent/prompts \
             /home/node/.pi/agent/themes \
             /home/node/.local/share/pi \
             /home/node/.config

# Pre-populate Pi's global MCP config to point directly to the gateway network container
RUN echo '{"mcpServers":{"mcp-gateway":{"url":"http://mcp-gateway:8811/sse","directTools":true,"lifecycle":"keep-alive"}}}' > /home/node/.pi/agent/mcp.json

RUN chown -R 1000:1000 /app && \
    chown -R 1000:1000 /home/node/.pi && \
    chown -R 1000:1000 /home/node/.local && \
    chown -R 1000:1000 /home/node/.config

USER node
WORKDIR /app
