# --- Stage 1: Grab Bun binary ---
FROM oven/bun:alpine AS bun-source

# --- Stage 2: Build Beads from source ---
# We use golang:alpine to ensure we have a full build environment
FROM golang:alpine AS beads-builder

RUN apk add --no-cache curl tar

# Build Beads (bd CLI)
RUN curl -fsSL https://github.com/gastownhall/beads/archive/refs/heads/main.tar.gz -o /tmp/beads.tar.gz && \
    tar -xzf /tmp/beads.tar.gz -C /tmp && \
    cd /tmp/beads-main && \
    CGO_ENABLED=0 go build -o /usr/local/bin/bd ./cmd/bd

# Download Dolt (Database backend)
RUN curl -fsSL https://github.com/dolthub/dolt/releases/download/v1.85.0/dolt-linux-amd64.tar.gz -o /tmp/dolt.tar.gz && \
    tar -xzf /tmp/dolt.tar.gz -C /tmp && \
    mv /tmp/dolt-linux-amd64/bin/dolt /usr/local/bin/dolt

# --- Stage 3: Final Image ---
FROM node:22-alpine

USER root

# Install runtime dependencies
RUN apk add --no-cache \
    curl \
    bash \
    unzip \
    icu-libs \
    gcompat

COPY --from=beads-builder /usr/local/bin/bd /usr/local/bin/bd
COPY --from=beads-builder /usr/local/bin/dolt /usr/local/bin/dolt

# Create the Git Shim for Beads stealth mode
# This allows 'bd init' to work without a real git installation
RUN echo -e '#!/bin/sh\nexit 0' > /usr/local/bin/git && \
    chmod +x /usr/local/bin/git

# Install Pi AI coding tool globally via npm
RUN npm install -g @earendil-works/pi-coding-agent

# Create Pi's global config directory structure (~/.pi/agent/)
RUN mkdir -p /home/devuser/.pi/agent/extensions \
    /home/devuser/.pi/agent/skills \
    /home/devuser/.pi/agent/prompts \
    /home/devuser/.pi/agent/themes

# Create the Pi project config directory template
RUN mkdir -p /app/.pi

ARG USER_ID=1000
ARG GROUP_ID=1000
ARG PROJECT_NAME

RUN addgroup -g $GROUP_ID devgroup || true && \
    adduser -D -u $USER_ID -G devgroup devuser || true

RUN mkdir -p /home/devuser/.local/share/pi \
    /home/devuser/.config && \
    chown -R devuser:devgroup /home/devuser /app

RUN mkdir -p /app/${PROJECT_NAME}/.sisyphus && \
    chown -R devuser:devgroup /app/${PROJECT_NAME}/.sisyphus

# Pre-populate Pi's global MCP config to connect to the gateway
RUN mkdir -p /home/devuser/.pi/agent && \
    echo '{"mcpServers":{"mcp-gateway":{"url":"http://mcp-gateway:8811/sse","directTools":true,"lifecycle":"keep-alive"}}}' > /home/devuser/.pi/agent/mcp.json && \
    chown devuser:devgroup /home/devuser/.pi/agent/mcp.json

USER devuser

WORKDIR /app
