# --- Stage 1: Compile tracking utilities ---
FROM golang:alpine AS builder
RUN apk add --no-cache curl tar
RUN curl -fsSL https://github.com/gastownhall/beads/archive/refs/heads/main.tar.gz -o /tmp/beads.tar.gz && \
    tar -xzf /tmp/beads.tar.gz -C /tmp && \
    cd /tmp/beads-main && \
    CGO_ENABLED=0 go build -o /usr/local/bin/bd ./cmd/bd

RUN curl -fsSL https://github.com/dolthub/dolt/releases/download/v1.85.0/dolt-linux-amd64.tar.gz -o /tmp/dolt.tar.gz && \
    tar -xzf /tmp/dolt.tar.gz -C /tmp && \
    mv /tmp/dolt-linux-amd64/bin/dolt /usr/local/bin/dolt

# --- Stage 2: Clean, Isolated Antigravity CLI Runtime ---
FROM debian:12-slim
USER root

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    bash \
    unzip \
    ca-certificates \
    python3 \
    && rm -rf /var/lib/apt/lists/*

# Copy compiled binaries from Stage 1
COPY --from=builder /usr/local/bin/bd /usr/local/bin/bd
COPY --from=builder /usr/local/bin/dolt /usr/local/bin/dolt

# Download and install the Antigravity CLI binary directly to /usr/local/bin
RUN curl -fsSL https://antigravity.google/cli/install.sh | bash && \
    mv /root/.local/bin/agy /usr/local/bin/agy

# Strict Zero-Trust Boundary: Enforce git block
RUN echo -e '#!/bin/sh\necho "Error: Direct Host Git access is restricted. Use the MCP server gateway."\nexit 1' > /usr/local/bin/git && \
    chmod +x /usr/local/bin/git

# Create isolated execution spaces matching expected local paths for plugins/state configurations
RUN useradd -m -s /bin/bash -u 1000 devuser

# Pre-create paths with consistent naming aligned with Compose mounts
RUN mkdir -p /app \
             /home/devuser/.gemini/antigravity-cli/skills \
             /home/devuser/.config/antigravity \
             /home/devuser/.cache/antigravity && \
    chown -R devuser:devuser /app /home/devuser

USER devuser
WORKDIR /app

ENV PATH="/usr/local/bin:${PATH}"

CMD ["bash"]
