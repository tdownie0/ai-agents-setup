{
  "name": "@model_md/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "seed": "tsx ./src/seed.ts",
    "seed:clear": "tsx ./src/seed.ts --clear",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "sh -c 'psql $DATABASE_URL -c \"DROP SCHEMA public CASCADE; DROP SCHEMA IF EXISTS drizzle CASCADE; CREATE SCHEMA public;\" && drizzle-kit migrate'"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^3.0.5"
  }
}
