version: 3
name: local-mcp
displayName: Local Development Catalog
registry:
  ast-explorer:
    title: "My Custom Python MCP"
    description: "Personal tools for OpenCode integration"
    type: server
    dateAdded: "2026-02-20T17:55:00Z"
    image: ast-explorer:latest
    metadata:
      category: utility
      tags:
        - local
        - python
    volumes:
      - ${PROJECT_PARENT_PATH}:/app
    env:
      - name: PYTHONUNBUFFERED
        value: "1"
      - name: REDIS_HOST
        value: "cache"
      - name: WORKSPACE_ROOT
        value: "/app"
      - name: DEFAULT_PROJECT
        value: "model_md"
      - name: DOCKER_MCP_TRANSPORT
        value: "stdio"
    tools:
      - name: scan_specific_file
        description: "Deep scan a single file to refresh its AST cache or get detailed signatures. Use when precision is needed for one file."
      - name: get_repo_map
        description: "Generates a high-level overview of a directory's structure, classes, and functions. Best for initial project exploration."
      - name: find_symbol
        description: "Search for a symbol name (class/function) across indexed files. Optionally filter by project/folder."
      - name: get_dependents
        description: "Lists all files that import the target file. Essential for understanding dependencies and the impact of code changes."

  supabase-manager:
    title: "Supabase DB Manager"
    description: "MCP for managing Supabase users and stats via Drizzle"
    type: server
    dateAdded: "2026-03-04T13:00:00Z"
    image: supabase-manager:latest
    metadata:
      category: database
      tags:
        - typescript
        - postgres
        - supabase
    networks:
      - supabase_network
    volumes:
      - ${PROJECT_PATH}:/app
    env:
      - name: DATABASE_URL
        value: ${TASKFILE_DATABASE_URL}
      - name: DOCKER_MCP_TRANSPORT
        value: "stdio"
    tools:
      - name: get_user_stats
        description: "Returns the total count of users and recent signups from the database."

  git-orchestrator:
    title: "Git Worktree Orchestrator"
    description: "Atomic management of isolated feature environments and git worktrees"
    type: server
    image: git-orchestrator:latest
    allowedPaths:
      - "${PROJECT_PARENT_PATH}"
      - "/app/"
    volumes:
      - ${PROJECT_PARENT_PATH}:/app
      - /var/run/docker.sock:/var/run/docker.sock
    env:
      - name: PYTHONUNBUFFERED
        value: "1"
      - name: WORKSPACE_ROOT
        value: "/app"
      - name: PROJECT_PARENT_PATH
        value: "${PROJECT_PARENT_PATH}"
      - name: USER_ID
        value: "1000"
      - name: GROUP_ID
        value: "1000"
    tools:
      - name: initialize_worktree
        description: "Creates a new git worktree, allocates ports, and starts the feature Docker environment."
      - name: execute_lifecycle
        description: "Executes a container-based lifecycle action: 'initialize' (db reset/seed), 'generate' (drizzle/codegen), 'migrate', 'seed', 'verify' (tests/lint), or 'build'."
      - name: git_ops
        description: "Executes safe Git commands (add, commit, status, diff, log, branch)."
      - name: get_environment_status
        description: "Returns the status of all containers for a given feature branch."
      - name: list_features
        description: "Lists all active feature worktrees."
      - name: stop_environment
        description: "Tears down the docker-compose environment and cleans up volumes."
