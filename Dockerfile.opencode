FROM ghcr.io/anomalyco/opencode:latest

USER root

ARG USER_ID=1000
ARG GROUP_ID=1000

RUN addgroup -g $GROUP_ID devgroup || true && \
    adduser -D -u $USER_ID -G devgroup devuser || true

RUN mkdir -p /home/devuser/.local/share/opencode \
             /home/devuser/.config/opencode \
             /home/devuser/.local/state \
             /app && \
    chown -R devuser:devgroup /home/devuser /app

USER devuser
WORKDIR /app
